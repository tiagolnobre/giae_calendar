# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env*.erb

# Ignore all logfiles and tempfiles.
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/storage/*.sqlite3
/storage/*.sqlite3-*

# Ignore public assets (compiled from app/assets).
/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore IDE/editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Ignore Ruby LSP cache
.ruby-lsp/

# Ignore coverage reports
/coverage/

# Ignore generated documentation
/doc/

# Ignore simplecov results
/coverage/

# Ignore byebug history
.byebug_history

# Ignore node_modules if using npm/yarn
/node_modules/
/yarn-error.log

# Ignore compiled Python files
*.pyc

# Ignore backup files
*.bak
*~

# Ignore local database configuration overrides
/config/database.yml.local

# Ignore litestream configuration if it contains secrets
/tmp/litestream.yml

# Ignore Kamal secrets
.kamal/secrets*

# Ignore fly.io secrets if any
.fly/

# Ignore key files for decrypting credentials and more.
/config/*.key

