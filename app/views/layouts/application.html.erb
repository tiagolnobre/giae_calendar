<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || t("app_name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="application-name" content="<%= t("app_name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#5DD3B6">

    <link rel="manifest" href="/manifest.json">

    <meta property="og:title" content="<%= content_for(:title) || t("app_name") %>">
    <meta property="og:description" content="<%= t("app_name") %> - <%= t("calendar.meals") %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= asset_path("og-image.png") %>">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for(:title) || t("app_name") %>">
    <meta name="twitter:description" content="<%= t("app_name") %> - <%= t("calendar.meals") %>">
    <meta name="twitter:image" content="<%= asset_path("og-image.png") %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= Sentry.get_trace_propagation_meta.html_safe %>
  </head>
  <body class="bg-gray-50">
    <% if user_signed_in? %>
      <nav class="bg-white border-b border-gray-200 px-4 py-3">
        <div class="max-w-md mx-auto flex items-center justify-between">
          <%= link_to root_path do %>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" class="h-8 w-8">
              <rect x="0" y="0" width="64" height="64" rx="6" ry="6" fill="#012a4a"/>
              <text x="50%" y="55%" text-anchor="middle" dominant-baseline="middle" font-family="system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" font-weight="800" font-size="22" letter-spacing="1" fill="#ffffff">GIAE</text>
            </svg>
          <% end %>
          <div class="flex items-center gap-2 sm:gap-4">
            <% latest_saldo = SaldoRecord.latest_for_user(current_user) %>
            <% if latest_saldo %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <%= number_to_currency(latest_saldo.cents / 100.0, unit: "€", separator: ",", delimiter: ".") %>
              </span>
            <% end %>
            <% has_notifications = current_user.notifications.unread.any? %>
            <div class="relative" data-controller="dropdown">
              <button type="button" data-action="dropdown#toggle" class="relative text-gray-600 hover:text-gray-800 touch-manipulation p-1">
                <% if has_notifications %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell-dot"><path d="M10.268 21a2 2 0 0 0 3.464 0"/><path d="M11.68 2.009A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673c-.824-.85-1.678-1.731-2.21-3.348"/><circle cx="18" cy="5" r="3"/></svg>
                <% else %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell"><path d="M10.268 21a2 2 0 0 0 3.464 0"/><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"/></svg>
                <% end %>
              </button>
              <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-80 bg-white rounded-lg shadow-lg border border-gray-200 z-50">
                <div class="p-3 border-b border-gray-100">
                  <span class="font-semibold text-gray-800"><%= t("nav.notifications") %></span>
                </div>
                <div class="max-h-80 overflow-y-auto">
                  <% notifications = current_user.notifications.order(created_at: :desc).limit(10) %>
                  <% if notifications.any? %>
                    <% notifications.each do |notification| %>
                      <div class="p-3 border-b border-gray-50 hover:bg-gray-50 <%= notification.read_at ? 'opacity-60' : '' %>">
                        <p class="text-sm text-gray-800"><%= notification.body %></p>
                        <p class="text-xs text-gray-500 mt-1"><%= l notification.created_at, format: :short %></p>
                        <% unless notification.read_at %>
                          <%= button_to t("nav.mark_read"),
                              mark_notification_read_path(notification),
                              method: :patch,
                              class: "text-xs text-blue-600 hover:text-blue-800 mt-1" %>
                        <% end %>
                      </div>
                    <% end %>
                  <% else %>
                    <p class="p-4 text-sm text-gray-500 text-center"><%= t("nav.no_notifications") %></p>
                  <% end %>
                </div>
                <%= link_to t("nav.view_all"), notifications_path, class: "block p-3 text-center text-sm text-blue-600 hover:text-blue-800 border-t border-gray-100" %>
              </div>
            </div>
            <div class="relative" data-controller="dropdown">
              <button type="button" data-action="dropdown#toggle" class="text-gray-600 hover:text-gray-800 touch-manipulation p-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
              </button>
              <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 z-50">
                <div class="py-1">
                  <button type="button" id="push-toggle" class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 flex items-center gap-2" data-is-subscribed="<%= current_user.push_subscriptions.any? %>">
                    <% if current_user.push_subscriptions.any? %>
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><path d="M10.268 21a2 2 0 0 0 3.464 0"/><path d="M11.68 2.009A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673c-.824-.85-1.678-1.731-2.21-3.348"/><circle cx="18" cy="5" r="3"/></svg>
                      <span>Notifications: ON</span>
                    <% else %>
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-500"><path d="M10.268 21a2 2 0 0 0 3.464 0"/><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"/></svg>
                      <span>Enable Notifications</span>
                    <% end %>
                  </button>
                  <%= button_to sign_out_path,
                      method: :delete,
                      class: "w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-100 flex items-center gap-2" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
                    <span>Log out</span>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </nav>
      <script>
        (function() {
          var btn = document.getElementById('push-toggle');
          btn.addEventListener('click', async function() {
            var isSubscribed = btn.dataset.isSubscribed === 'true';
            if (isSubscribed) {
              await fetch('/push_subscriptions?endpoint=', { method: 'DELETE', headers: { 'X-CSRF-Token': '<%= form_authenticity_token %>' } });
              btn.dataset.isSubscribed = 'false';
              btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-500"><path d="M10.268 21a2 2 0 0 0 3.464 0"/><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"/></svg><span>Enable Notifications</span>';
            } else {
              var perm = await Notification.requestPermission();
              if (perm !== 'granted') return;
              var reg = await navigator.serviceWorker.ready;
              var vapidKey = '<%= Rails.application.credentials.dig(:webpush, :vapid_public_key) || ENV.fetch("VAPID_PUBLIC_KEY", "") %>';
              var sub = await reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: urlBase64ToUint8Array(vapidKey) });
              var response = await fetch('/push_subscriptions', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= form_authenticity_token %>' }, body: JSON.stringify({ subscription: sub.toJSON() }) });
              if (response.ok) {
                btn.dataset.isSubscribed = 'true';
                btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><path d="M10.268 21a2 2 0 0 0 3.464 0"/><path d="M11.68 2.009A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673c-.824-.85-1.678-1.731-2.21-3.348"/><circle cx="18" cy="5" r="3"/></svg><span>Notifications: ON</span>';
              }
            }
          });
          function urlBase64ToUint8Array(base64String) {
            var padding = '='.repeat((4 - (base64String.length % 4)) % 4);
            var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
            var rawData = window.atob(base64);
            var outputArray = new Uint8Array(rawData.length);
            for (var i = 0; i < rawData.length; ++i) { outputArray[i] = rawData.charCodeAt(i); }
            return outputArray;
          }
        })();
      </script>
    <% end %>

    <% if notice %>
      <div class="max-w-md mx-auto mt-4 px-4">
        <div class="bg-green-50 text-green-800 px-4 py-3 rounded-lg text-sm"><%= notice %></div>
      </div>
    <% end %>

    <% if alert %>
      <div class="max-w-md mx-auto mt-4 px-4">
        <div class="bg-red-50 text-red-800 px-4 py-3 rounded-lg text-sm"><%= alert %></div>
      </div>
    <% end %>

    <%= yield %>

    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js')
            .then((registration) => {
              console.log('SW registered:', registration.scope);
            })
            .catch((error) => {
              console.log('SW registration failed:', error);
            });
        });
      }
    </script>
  </body>
</html>
