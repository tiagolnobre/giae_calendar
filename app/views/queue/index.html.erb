<div class="min-h-screen bg-gray-50 p-6">
  <div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Solid Queue Dashboard</h1>
    
    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
      <div class="bg-white rounded-lg shadow p-4">
        <div class="text-sm text-gray-600">Ready</div>
        <div class="text-2xl font-bold text-blue-600"><%= @ready_jobs %></div>
      </div>
      <div class="bg-white rounded-lg shadow p-4">
        <div class="text-sm text-gray-600">Scheduled</div>
        <div class="text-2xl font-bold text-yellow-600"><%= @scheduled_jobs %></div>
      </div>
      <div class="bg-white rounded-lg shadow p-4">
        <div class="text-sm text-gray-600">Failed</div>
        <div class="text-2xl font-bold text-red-600"><%= @failed_jobs %></div>
      </div>
      <div class="bg-white rounded-lg shadow p-4">
        <div class="text-sm text-gray-600">Claimed</div>
        <div class="text-2xl font-bold text-green-600"><%= @claimed_jobs %></div>
      </div>
      <div class="bg-white rounded-lg shadow p-4">
        <div class="text-sm text-gray-600">Blocked</div>
        <div class="text-2xl font-bold text-purple-600"><%= @blocked_jobs %></div>
      </div>
    </div>
    
    <!-- Recent Jobs -->
    <div class="bg-white rounded-lg shadow mb-6">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-xl font-semibold text-gray-800">Recent Jobs</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-xs font-medium text-gray-500 uppercase">ID</th>
              <th class="px-6 py-3 text-xs font-medium text-gray-500 uppercase">Class</th>
              <th class="px-6 py-3 text-xs font-medium text-gray-500 uppercase">Queue</th>
              <th class="px-6 py-3 text-xs font-medium text-gray-500 uppercase">Priority</th>
              <th class="px-6 py-3 text-xs font-medium text-gray-500 uppercase">Created</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @recent_jobs.each do |job| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-sm text-gray-900"><%= job.id %></td>
                <td class="px-6 py-4 text-sm text-gray-900"><%= job.class_name %></td>
                <td class="px-6 py-4 text-sm text-gray-600"><%= job.queue_name %></td>
                <td class="px-6 py-4 text-sm text-gray-600"><%= job.priority %></td>
                <td class="px-6 py-4 text-sm text-gray-600"><%= time_ago_in_words(job.created_at) %> ago</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    
    <!-- Failed Jobs -->
    <% if @failed_executions.any? %>
      <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-xl font-semibold text-gray-800">Failed Jobs</h2>
        </div>
        <div class="divide-y divide-gray-200">
          <% @failed_executions.each do |execution| %>
            <div class="px-6 py-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-gray-900"><%= execution.job.class_name %></span>
                <span class="text-xs text-gray-500"><%= time_ago_in_words(execution.created_at) %> ago</span>
              </div>
              <div class="text-sm text-red-600 bg-red-50 p-3 rounded">
                <%= execution.error %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
