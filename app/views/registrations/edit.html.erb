<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4 py-8">
  <div class="max-w-md w-full">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-gray-900"><%= t("account.edit_account") %></h1>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6">
      <%= form_with model: @user, url: account_path, method: :patch, class: "space-y-4" do |f| %>
        <% if @user.errors.any? %>
          <div class="bg-red-50 text-red-800 px-4 py-3 rounded-lg text-sm">
            <ul class="list-disc list-inside">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :email, t("session.email"), class: "block text-sm font-medium text-gray-700" %>
          <%= f.email_field :email, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div class="border-t pt-4">
          <h3 class="text-lg font-medium text-gray-900 mb-3">GIAE</h3>
          
          <div class="space-y-3">
            <div>
              <%= f.label :giae_username, t("registration.giae_username"), class: "block text-sm font-medium text-gray-700" %>
              <%= f.text_field :giae_username, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
            </div>

            <div>
              <%= f.label :giae_password, t("registration.giae_password"), class: "block text-sm font-medium text-gray-700" %>
              <%= f.password_field :giae_password, class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
            </div>
          </div>
        </div>

        <div class="border-t pt-4">
          <h3 class="text-lg font-medium text-gray-900 mb-3"><%= t("account.change_password") %></h3>
          
          <div class="space-y-3">
            <div>
              <%= f.label :password, t("session.password"), class: "block text-sm font-medium text-gray-700" %>
              <%= f.password_field :password, autocomplete: "new-password", placeholder: t("registration.leave_blank"), class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
            </div>

            <div>
              <%= f.label :password_confirmation, t("registration.confirm_password"), class: "block text-sm font-medium text-gray-700" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
            </div>
          </div>
        </div>

        <div class="flex gap-3">
          <%= f.submit t("account.update_account"), class: "flex-1 bg-blue-600 text-white py-2 px-4 rounded-lg hover:bg-blue-700 transition-colors font-medium" %>
        </div>
      <% end %>

      <div class="mt-6 pt-6 border-t">
        <%= button_to t("nav.sign_out"), sign_out_path, method: :delete, class: "w-full bg-gray-100 text-gray-700 py-2 px-4 rounded-lg hover:bg-gray-200 transition-colors" %>
      </div>
    </div>

    <div class="mt-4 text-center">
      <%= link_to "← " + t("nav.back"), root_path, class: "text-blue-600 hover:text-blue-800" %>
    </div>
  </div>
</div>