<div class="min-h-screen bg-gray-50">
  <div class="max-w-md mx-auto px-4 py-6">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-900"><%= t("calendar.meals") %></h1>
      <%= button_to refresh_calendar_path,
          method: :post,
          class: "px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors text-sm font-medium #{@user.refresh_in_progress? ? 'opacity-50 cursor-not-allowed' : ''}",
          data: { turbo_submits_with: t("calendar.refreshing") },
          disabled: @user.refresh_in_progress? do %>
        <%= t("calendar.refresh") %>
      <% end %>
    </div>

    <div id="refresh-status">
      <%= render "refresh_status", user: @user, refreshing: @user.refresh_in_progress? %>
    </div>

    <% if @today_details %>
      <div class="bg-white rounded-xl shadow-sm p-4 mb-4">
        <h3 class="text-lg font-semibold text-gray-800 mb-3"><%= t("calendar.today_menu") %></h3>
        <div class="space-y-2 text-sm">
          <% if @today_details.soup.present? %>
            <div class="flex items-start">
              <span class="font-medium text-gray-500 w-20"><%= t("calendar.soup") %>:</span>
              <span class="text-gray-800"><%= @today_details.soup %></span>
            </div>
          <% end %>
          <% if @today_details.main_dish.present? %>
            <div class="flex items-start">
              <span class="font-medium text-gray-500 w-20"><%= t("calendar.main_dish") %>:</span>
              <span class="text-gray-800"><%= @today_details.main_dish %></span>
            </div>
          <% end %>
          <% if @today_details.vegetables.present? %>
            <div class="flex items-start">
              <span class="font-medium text-gray-500 w-20"><%= t("calendar.vegetables") %>:</span>
              <span class="text-gray-800"><%= @today_details.vegetables %></span>
            </div>
          <% end %>
          <% if @today_details.dessert.present? %>
            <div class="flex items-start">
              <span class="font-medium text-gray-500 w-20"><%= t("calendar.dessert") %>:</span>
              <span class="text-gray-800"><%= @today_details.dessert %></span>
            </div>
          <% end %>
          <% if @today_details.bread.present? %>
            <div class="flex items-start">
              <span class="font-medium text-gray-500 w-20"><%= t("calendar.bread") %>:</span>
              <span class="text-gray-800"><%= @today_details.bread %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
      <div class="px-4 py-3 bg-gray-50 border-b border-gray-100 flex items-center justify-between">
        <%= link_to calendar_path(month: @month > 1 ? @month - 1 : 12, year: @month > 1 ? @year : @year - 1),
            class: "p-2 hover:bg-gray-200 rounded-lg transition-colors",
            data: { turbo_action: "replace" } do %>
          <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        <% end %>
        <h2 class="text-lg font-semibold text-gray-800">
          <%= I18n.t("date.month_names")[@month] %> <%= @year %>
        </h2>
        <%= link_to calendar_path(month: @month < 12 ? @month + 1 : 1, year: @month < 12 ? @year : @year + 1),
            class: "p-2 hover:bg-gray-200 rounded-lg transition-colors",
            data: { turbo_action: "replace" } do %>
          <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>

      <div class="grid grid-cols-7 gap-px bg-gray-200">
        <% [t("days.mon"), t("days.tue"), t("days.wed"), t("days.thu"), t("days.fri"), t("days.sat"), t("days.sun")].each do |day| %>
          <div class="bg-gray-50 py-2 text-center text-xs font-medium text-gray-500 uppercase">
            <%= day %>
          </div>
        <% end %>

        <% @calendar_days.each do |day| %>
          <div class="<%= day_classes(day) %> <%= day[:is_current_month] && !day[:is_weekend] && !day[:is_holiday] ? 'cursor-pointer hover:bg-gray-100' : '' %> transition-colors" 
               style="<%= day_style(day) %>"
               <%= day[:is_current_month] && !day[:is_weekend] && !day[:is_holiday] ? "data-action=\"click->modal#open\" data-date=\"#{day[:date]}\"".html_safe : '' %>>
            <% if day[:is_current_month] && !day[:is_weekend] && !day[:is_holiday] %>
              <%= link_to day_details_path(date: day[:date]), 
                  class: "w-full h-full flex items-center justify-center", 
                  data: { turbo_frame: "day_modal" } do %>
                <% if day[:ticket] %>
                  <div class="relative w-full h-full flex items-center justify-center">
                    <div class="rounded-full w-7 h-7 flex items-center justify-center text-sm font-medium" style="<%= day[:ticket].bought ? 'background-color: #5DD3B6; color: white;' : 'background-color: #D1D5DB; color: #374151;' %>">
                      <%= day[:date].day %>
                    </div>
                    <% if day[:ticket].dish_type_icon %>
                      <span class="absolute -top-1 -right-1"><%= raw day[:ticket].dish_type_icon %></span>
                    <% end %>
                  </div>
                <% else %>
                  <div class="text-gray-400 text-sm"><%= day[:date].day %></div>
                <% end %>
              <% end %>
            <% else %>
              <span class="text-gray-300 text-sm"><%= day[:date].day %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%= turbo_frame_tag "day_modal" %>

    <div class="mt-4 flex items-center justify-between text-sm">
      <div class="flex gap-4">
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 rounded-full" style="background-color: #5DD3B6;"></div>
          <span class="text-gray-600"><%= t("calendar.bought") %></span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 bg-gray-300 rounded-full"></div>
          <span class="text-gray-600"><%= t("calendar.not_bought") %></span>
        </div>
      </div>
      <%= link_to t("calendar.edit_credentials"), edit_account_path, class: "text-blue-600 hover:text-blue-800" %>
    </div>
  </div>
</div>